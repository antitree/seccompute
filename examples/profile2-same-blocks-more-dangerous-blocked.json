    {
      "_comment": "EXPLICIT blocks for ALL Tier 1 dangerous syscalls (defense-in-depth).",
      "_security_note": "These are already blocked by defaultAction but made explicit.",
      "names": [
        "bpf", "ptrace",
        "kexec_load", "kexec_file_load",
        "init_module", "finit_module", "delete_module",
        "process_vm_readv", "process_vm_writev"
      ],
      "action": "SCMP_ACT_ERRNO"
    },
    {
      "_comment": "EXPLICIT blocks for ALL Tier 2 dangerous syscalls (defense-in-depth).",
      "names": [
        "io_uring_setup", "io_uring_enter", "io_uring_register",
